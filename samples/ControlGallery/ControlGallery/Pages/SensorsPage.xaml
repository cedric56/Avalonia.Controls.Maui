<ContentPage x:Class="ControlGallery.Pages.SensorsPage"
             Title="Sensors">
    <ScrollView>
        <VerticalStackLayout Padding="20"
                         Spacing="20">


            <!-- Accelerometer -->
            <Border Stroke="Gray"
                Padding="10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Accelerometer"
                       FontAttributes="Bold"/>
                    <Button Text="Start"
                        Clicked="OnAccelerometerStart"/>
                    <Button Text="Stop"
                        Clicked="OnAccelerometerStop"/>
                    <Label x:Name="AccelerometerLabel"
                       Text="File: --"
                       FontAttributes="Italic"/>
                    <Label x:Name="ShakeLabel"
                        Text="File: --"
                        FontAttributes="Italic"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>