<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaSandboxApp.SensorsPage">
  <ScrollViewer>
        <StackPanel Margin="20" Spacing="20">

            <!-- Accelerometer -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="Accelerometer" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Start" Click="OnStartAccelerometer"/>
                        <Button Content="Stop" Click="OnStopAccelerometer"/>
                    </StackPanel>

                    <TextBlock x:Name="AccelerometerLabel"
                               Text="--"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- Barometer -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="Barometer" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Start" Click="OnStartBarometer"/>
                        <Button Content="Stop" Click="OnStopBarometer"/>
                    </StackPanel>

                    <TextBlock x:Name="BarometerLabel"
                               Text="--"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- Gyroscope -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="Gyroscope" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Start" Click="OnStartGyroscope"/>
                        <Button Content="Stop" Click="OnStopGyroscope"/>
                    </StackPanel>

                    <TextBlock x:Name="GyroscopeLabel"
                               Text="--"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- Magnetometer -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="Magnetometer" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Start" Click="OnStartMagnetometer"/>
                        <Button Content="Stop" Click="OnStopMagnetometer"/>
                    </StackPanel>

                    <TextBlock x:Name="MagnetometerLabel"
                               Text="--"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>

            <!-- Compass -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="10" CornerRadius="10">
                <StackPanel Spacing="10">
                    <TextBlock Text="Compass" FontWeight="Bold"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Start" Click="OnStartCompass"/>
                        <Button Content="Stop" Click="OnStopCompass"/>
                    </StackPanel>

                    <TextBlock x:Name="CompassLabel"
                               Text="--"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</ContentPage>
