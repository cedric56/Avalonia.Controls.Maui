<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaSandboxApp.FilePickerPage">
  
  <ScrollViewer>
    <StackPanel Margin="20" Spacing="20">

            <GroupBox Header="Pick Files" Margin="20" FontWeight="Bold">
            <StackPanel Spacing="10">

                <Button Content="Pick Single File" HorizontalAlignment="Center"
                        Click="OnPickSingleClicked"/>

                <Button Content="Pick Multiple Files" HorizontalAlignment="Center"
                        Click="OnPickMultipleClicked"/>

                <TextBlock x:Name="FileNameLabel"
                           Text="File: --"
                           FontStyle="Italic"/>

                <TextBlock x:Name="FilePathLabel"
                           Text="Path: --"
                           FontStyle="Italic"/>

            </StackPanel>
            </GroupBox>
    </StackPanel>
</ScrollViewer>

</ContentPage>
